{
  "manifest_version": 3,
  "name": "M3U8 Sniffer (Edge)",
  "version": "1.0.0",
  "description": "自动扫描网页中的 m3u8 视频链接，在视频下方展示并支持一键复制",
  "minimum_edge_version": "88.0.0.0",
  "permissions": [
    "webRequest",
    "storage"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["http://*/*", "https://*/*"],
      "js": ["content-script.js"],
      "run_at": "document_idle",
      "all_frames": true
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
